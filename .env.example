# Cloudflare API Token（推荐，Bearer 方式）
# 在 https://dash.cloudflare.com/profile/api-tokens 创建
# 权限建议：Workers Scripts:Edit, Workers Routes:Edit, Zone:DNS:Edit,
#          SSL and Certificates:Edit, Account:Workers AI:Read
CLOUDFLARE_API_TOKEN=

# 可选：显式指定账号/域，不填 deploy_worker.py 会自动取第一个账号
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_NAME=idai.asia
CLOUDFLARE_ZONE_ID=

# ---- 可选：使用 Global API Key（遗留方式）----
# CLOUDFLARE_EMAIL=you@example.com
# CLOUDFLARE_API_KEY=your_global_api_key
